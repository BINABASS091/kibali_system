# Backend Environment Variables (Copy to .env)
# This file shows all configurable environment variables for the backend

# Django Settings
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Preferred (Neon): single connection URL from Neon dashboard
# Example format:
# DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Optional local fallback settings (used only if DATABASE_URL is empty)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=kibali_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Storage
MEDIA_ROOT=media/
MEDIA_URL=/media/

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# Logging (optional)
LOG_LEVEL=INFO
